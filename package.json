{
  "name": "trail-safe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run src/tests/unit --passWithNoTests",
    "test:int": "vitest run src/tests/integration --passWithNoTests",
    "test:e2e": "playwright test -c playwright.preview.config.js",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm run test:int && npm run test:e2e",
    "prepare": "husky",
    "test:e2e:dev": "playwright test"
  },
